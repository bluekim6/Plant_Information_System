# Plant Information System - Backend 환경설정 예시
# 실제 사용 시 이 파일을 .env 로 복사한다.
#
# 경로는 저장소 루트 기준 "상대경로" 로 적으면 PC 가 바뀌어도 그대로 동작한다.
# (엑셀/도면 파일이 저장소 루트에 함께 있는 기본 배치 기준)
# 데이터 파일을 저장소 밖 다른 위치에 둘 때만 절대경로로 바꾼다.
# 아래 값들은 .env 를 비워도 적용되는 기본값과 동일하다.

# 엑셀 데이터 파일 (저장소 루트 기준 상대경로)
TAG_REGISTER_PATH=Tag_Register.xlsx
DOCUMENT_LIST_PATH=Document_List.xlsx
DOCUMENT_TO_TAG_PATH=Document_to_Tag.xlsx
MANUFACTURE_LIST_PATH=Manufacture_list.xlsx

# 도면(PDF) 저장 폴더
DRAWING_STORAGE_PATH=Document_Storage

# Comment / History 저장 파일 (생략 시 backend/data/ 하위 자동 사용)
# COMMENTS_PATH=backend/data/comments.json
# HISTORY_PATH=backend/data/history.json

# 프론트엔드 dev server 오리진 (필요 시 수정)
# CORS_ORIGINS=["http://localhost:5173"]
