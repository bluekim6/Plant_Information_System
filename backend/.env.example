# Plant Information System - Backend 환경설정 예시
# 실제 사용 시 이 파일을 .env 로 복사하여 경로를 본인 PC에 맞게 수정한다.

# 엑셀 데이터 파일 (절대경로 권장)
TAG_REGISTER_PATH=D:/code/EngineeringDT_2/Tag_Register.xlsx
DOCUMENT_LIST_PATH=D:/code/EngineeringDT_2/Document_List.xlsx
DOCUMENT_TO_TAG_PATH=D:/code/EngineeringDT_2/Document_to_Tag.xlsx
MANUFACTURE_LIST_PATH=D:/code/EngineeringDT_2/Manufacture_list.xlsx

# 도면(PDF) 저장 폴더
DRAWING_STORAGE_PATH=D:/code/EngineeringDT_2/Document_Storage

# Comment / History 저장 파일 (생략 시 backend/data/ 하위 자동 사용)
# COMMENTS_PATH=D:/code/EngineeringDT_2/backend/data/comments.json
# HISTORY_PATH=D:/code/EngineeringDT_2/backend/data/history.json

# 프론트엔드 dev server 오리진 (필요 시 수정)
# CORS_ORIGINS=["http://localhost:5173"]
